# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Model configuration
MODEL_NAME=claude-sonnet-4-20250514
RESEARCH_MODEL_NAME=claude-sonnet-4-20250514

# Rubber Duck Escalator settings
RUBBER_DUCK_THRESHOLD=8
RUBBER_DUCK_MAX_ITERATIONS=3

# Paths (defaults work for most setups)
# DATA_DIR=./data
# SQLITE_PATH=./data/sqlite/creative_writer.db
# CHROMA_PATH=./data/chroma
